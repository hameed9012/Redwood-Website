# Copy to .env.local (gitignored) and fill in to enable real contact-form storage.
# Without these, the form runs in visual-only mode (shows a reference, stores nothing).
# See README.md → "Contact form storage (Supabase)" and supabase/schema.sql.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Portal server-side reads (service role — NEVER prefix with NEXT_PUBLIC)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
